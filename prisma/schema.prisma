generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url       = env("DATABASE_URL")
}

model ContactMessage {
  id          String   @id @default(cuid())
  name        String
  email       String
  phoneNumber String?
  subject     String
  message     String
  createdAt   DateTime @default(now())

  @@map("contact_messages")
}

model NewsletterSubscriber {
  id        String   @id @default(cuid())
  email     String   @unique
  source    String?
  createdAt DateTime @default(now())

  @@map("newsletter_subscribers")
}

model BlogPost {
  id          String   @id @default(cuid())
  slug        String   @unique
  category    String
  title       String
  excerpt     String
  content     String
  imageUrl    String?
  readTime    String?
  featured    Boolean  @default(false)
  publishedAt DateTime @default(now())
  createdAt   DateTime @default(now())

  @@map("blog_posts")
}

model Service {
  id          String   @id @default(cuid())
  name        String
  category    String
  price       String
  description String
  image       String?
  createdAt   DateTime @default(now())

  @@map("services")
}

model GalleryImage {
  id        String   @id @default(cuid())
  title     String
  imageUrl  String
  category  String
  createdAt DateTime @default(now())

  @@map("gallery_images")
}



